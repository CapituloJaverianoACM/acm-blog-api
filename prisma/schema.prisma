generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Comment {
  id          Int       @id @default(autoincrement())
  blog_id     Int
  parent_id   Int?
  content     String
  owner_id    Int
  created_at  DateTime  @db.Date
  last_update DateTime  @db.Date
  blog        Blog      @relation(fields: [blog_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student     student   @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parent      Comment?  @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     Comment[] @relation("CommentReplies")

  @@map("comment")
}

model Blog {
  id           Int            @id @default(autoincrement())
  title        String
  content      String
  created_at   DateTime       @db.Date
  last_update  DateTime       @db.Date
  latitude     Float?
  longitude    Float?
  published    Boolean
  blog_image   blog_image[]
  collaborator collaborator[]
  comments     Comment[]
  reaction     reaction[]

  @@map("blog")
}

model blog_image {
  id      Int    @id @default(autoincrement())
  blog_id Int
  alt     String
  url     String
  blog    Blog   @relation(fields: [blog_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("blog-image")
}

model collaborator {
  blog_id Int
  user_id Int
  blog    Blog    @relation(fields: [blog_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student student @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([blog_id, user_id])
}

model contest {
  id            Int             @id @default(autoincrement())
  name          String
  date          DateTime        @db.Date
  start_hour    DateTime        @db.Timestamp(6)
  final_hour    DateTime        @db.Timestamp(6)
  level         levelenum
  classroom     String?
  participation participation[]
  picture       picture[]
  results       results[]
}

model participation {
  contest_id Int
  student_id Int
  position   Int?
  checkin    Boolean? @default(false)
  contest    contest  @relation(fields: [contest_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student    student  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([contest_id, student_id])
}

model picture {
  id         Int     @id @default(autoincrement())
  contest_id Int
  link       String  @unique
  contest    contest @relation(fields: [contest_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model reaction {
  blog_id Int
  user_id Int
  type    reaction_type
  blog    Blog          @relation(fields: [blog_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student student       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([blog_id, user_id])
}

model results {
  local_id                             Int
  visitant_id                          Int
  winner_id                            Int?
  contest_id                           Int
  id                                   Int      @unique @default(autoincrement())
  contest                              contest  @relation(fields: [contest_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student_results_local_idTostudent    student  @relation("results_local_idTostudent", fields: [local_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student_results_visitant_idTostudent student  @relation("results_visitant_idTostudent", fields: [visitant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student_results_winner_idTostudent   student? @relation("results_winner_idTostudent", fields: [winner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([local_id, visitant_id, contest_id, id])
}

model student {
  id                                   Int             @id @default(autoincrement())
  name                                 String
  surname                              String
  matches_count                        Int?            @default(0)
  victory_count                        Int?            @default(0)
  level                                levelenum       @default(Initial)
  avatar                               String?         @default("")
  supabase_user_id                     String          @unique(map: "student_id2_key") @db.Uuid
  collaborator                         collaborator[]
  comment                              Comment[]
  participation                        participation[]
  reaction                             reaction[]
  results_results_local_idTostudent    results[]       @relation("results_local_idTostudent")
  results_results_visitant_idTostudent results[]       @relation("results_visitant_idTostudent")
  results_results_winner_idTostudent   results[]       @relation("results_winner_idTostudent")
}

enum levelenum {
  Initial
  Advanced
}

enum reaction_type {
  LIKE
  DISLIKE
  HEART
  ANGRY

  @@map("reaction-type")
}
